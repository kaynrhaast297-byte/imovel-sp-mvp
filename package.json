{
  "name": "imovel-sp-mvp",
  "version": "0.1.0",
  "description": "Platform for comparing real estate prices in São Paulo",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:devcheck": "node scripts/run-devcheck-tests.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:ui": "node scripts/run-e2e.mjs --ui",
    "test:e2e:report": "playwright show-report",
    "check": "npm run type-check && npm run lint && npm run test:coverage",
    "health": "node scripts/health-check.js",
    "check:fast": "npm run test",
    "check:full": "npm run check && npm run build && npm run test:e2e",
    "check:integration": "npm run type-check && npm run test && npm run test:devcheck",
    "check:security": "node scripts/security-check.mjs",
    "gate": "node scripts/run-devcheck.mjs approve",
    "gate:security": "node scripts/run-devcheck.mjs security",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "feature:new": "node scripts/create-feature.js",
    "report:validation": "node scripts/generate-validation-report.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.40.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.6.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.0.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.77.0",
    "swiper": "^12.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.2.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.0.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
