NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Use uma chave secreta apenas no servidor. Nunca use NEXT_PUBLIC neste valor.
# Preferencia atual da Supabase: SUPABASE_SECRET_KEY. Service role tambem e aceito pelo app.
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Token server-side usado somente para abrir a sessao HttpOnly do painel /admin.
IMOVEL_ADMIN_TOKEN=

# Tentativas de login admin por IP antes de bloqueio temporario.
ADMIN_LOGIN_RATE_LIMIT_MAX=5
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Limite local por IP para envios de lead. Use um limiter distribuido ao escalar.
LEAD_RATE_LIMIT_MAX=5
LEAD_RATE_LIMIT_WINDOW_MS=900000

# Geocodificacao server-side. Respeite a politica publica do Nominatim (max. 1 req/s).
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=ImovelSP-MVP/0.1

# Usados na home para botao e QR code do WhatsApp.
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_MESSAGE=

# Usados pela rota /api/ai para falar com Ollama local.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
